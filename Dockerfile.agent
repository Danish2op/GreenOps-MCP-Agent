FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
RUN pip install --no-cache-dir fastapi uvicorn

# Copy application and agent code
COPY greenops_agent/ greenops_agent/
COPY agent_app.py .

# Cloud Run expects the container to listen on $PORT (default 8080)
ENV PORT=8080
EXPOSE 8080

# Run the official ADK Web UI
CMD ["adk", "web", "--host", "0.0.0.0", "--port", "8080", "--no_use_local_storage", "--memory_service_uri", "memory://"]
