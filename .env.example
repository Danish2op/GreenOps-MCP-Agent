# Google Cloud Project ID (required for BigQuery queries)
GCP_PROJECT_ID=your-gcp-project-id

# Gemini API key (for ADK agent — use AI Studio key or Vertex AI)
GOOGLE_API_KEY=your-gemini-api-key

# MCP Server URL (default for local dev; override for Cloud Run deployment)
MCP_SERVER_URL=http://localhost:8080/sse
